# Application
APP_NAME="Recruitment Agent"
ENVIRONMENT=test
APP_DEBUG=false
LOG_LEVEL=WARNING

# API
API_HOST=127.0.0.1
API_PORT=8001
API_V1_PREFIX=/api/v1
CORS_ORIGINS=

# Database
DATABASE_URL=postgresql+asyncpg://recruitment:recruitment@localhost:5432/recruitment_test
DATABASE_ECHO=false
DATABASE_POOL_SIZE=1
DATABASE_MAX_OVERFLOW=0

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=recruitment-agent-test
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LLM provider
LLM_PROVIDER=test
LLM_MODEL_NAME=test-model
LLM_API_KEY=
LLM_TEMPERATURE=0

# Application
APP_NAME="Recruitment Agent"
ENVIRONMENT=local
APP_DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Postgres
POSTGRES_USER=recruitment
POSTGRES_PASSWORD=recruitment
POSTGRES_DB=recruitment
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://recruitment:recruitment@postgres:5432/recruitment
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=recruitment-agent
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LLM provider
LLM_PROVIDER=local
LLM_MODEL_NAME=not-configured
LLM_API_KEY=
LLM_TEMPERATURE=0

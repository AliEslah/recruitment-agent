# Application
APP_NAME="AI Recruiting Decision Platform"
APP_DEBUG=true
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=recruitment
POSTGRES_PASSWORD=recruitment
POSTGRES_DB=recruitment
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://recruitment:recruitment@localhost:5432/recruitment
DATABASE_ECHO=false

# LM Studio local OpenAI-compatible server
# Host backend: http://localhost:1234/v1
# Docker backend: http://host.docker.internal:1234/v1
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Project model routing
# Use a non-thinking model for structured JSON workflows. Keep thinking-only models
# out of the JSON workflow unless explicitly experimenting.
RECRUITING_LLM_MODEL=qwen/qwen3-4b-2507
RECRUITING_ALLOW_THINKING_MODEL_FOR_JSON=false

# Request settings sent by the backend to LM Studio
LM_STUDIO_TEMPERATURE=0.2
LM_STUDIO_TIMEOUT_SECONDS=180
LM_STUDIO_MAX_TOKENS=2048
LM_STUDIO_ENABLE_THINKING=false

# SMTP / Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=recruiting@example.local
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# JWT auth
# Replace this local value before using outside development.
JWT_SECRET_KEY=change-me-local-dev-only-32-bytes-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Optional local-only seed users for `uv run python -m app.scripts.seed_dev_users`
DEV_ADMIN_EMAIL=admin@example.local
DEV_ADMIN_PASSWORD=admin-password
DEV_RECRUITER_EMAIL=recruiter@example.local
DEV_RECRUITER_PASSWORD=recruiter-password
DEV_MANAGER_EMAIL=manager@example.local
DEV_MANAGER_PASSWORD=manager-password

# Interview security
INTERVIEW_TOKEN_TTL_HOURS=72
OTP_TTL_MINUTES=10
MAX_INTERVIEW_FOLLOW_UPS=2
